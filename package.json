{
  "name": "ermi-command-center",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "api": "python -m ermi.server --root archive --host 127.0.0.1 --port 8765",
    "dev": "node node_modules/vite/bin/vite.js --host 127.0.0.1",
    "dev:ui": "node node_modules/vite/bin/vite.js --host 127.0.0.1 --port 5173",
    "test": "python -m pytest -q",
    "build": "node node_modules/vite/bin/vite.js build",
    "preview": "node node_modules/vite/bin/vite.js preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
